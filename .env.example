# AllPlay UF — environment variables
#
# NOTE: These are documented here for future migration to env-based config.
# At the moment Supabase URL and anon key are HARDCODED in
# src/components/supabase/config.jsx as a deliberate workaround for an
# iOS/TestFlight bug where a backend-fetched anon key arrived as null and
# produced silent 403 responses. The anon key is a public key, so this is
# safe — see the header comment in config.jsx for full context.
#
# To run locally you do NOT currently need a .env file. These variables are
# listed so a new developer knows what would be needed if/when the project
# switches over to env-based Supabase config.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
